<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/android:windowBackground">

    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/screen_margin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            style="@style/Widget.Material3.Button.TextButton"
            android:text="Quay lại"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_medium"
            app:icon="@drawable/ic_home"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="240dp"
            android:layout_height="360dp"
            android:layout_gravity="center"
            app:cardCornerRadius="@dimen/card_corner_radius"
            app:cardElevation="8dp"
            app:strokeWidth="0dp">
            <ImageView
                android:id="@+id/imgBook"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Book Cover"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:textColor="?attr/colorOnSurface"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"/>

        <TextView
            android:id="@+id/txtAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_small"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="20sp"
            android:gravity="center_horizontal"/>

        <TextView
            android:id="@+id/txtCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_category_tag"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:text="Thể loại: Khác"/>

        <LinearLayout
            android:id="@+id/adminControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_large"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditBook"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="Sửa sách"
                app:icon="@android:drawable/ic_menu_edit" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteBook"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Xóa sách"
                app:icon="@android:drawable/ic_menu_delete"
                app:backgroundTint="?attr/colorErrorContainer"
                app:tint="?attr/colorOnErrorContainer" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReadBook"
            style="@style/AppButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_large"
            android:text="Đọc sách "
            android:visibility="gone" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="@dimen/spacing_large"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_small">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mô tả"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditDescription"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                app:icon="@android:drawable/ic_menu_edit"
                android:visibility="gone"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nội dung mô tả sách đang được cập nhật..."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"/>

    </LinearLayout>
</ScrollView>
