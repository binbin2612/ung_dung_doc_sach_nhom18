<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppReadingBook">
        <activity
            android:name="com.example.ngdungocsach.admin.AdminActivity"
            android:exported="false" />
        <activity
            android:name="com.example.ngdungocsach.admin.EditBookActivity"
            android:exported="false" />
        <activity
            android:name="com.example.ngdungocsach.admin.ManageUsersActivity"
            android:exported="false" />
        <activity
            android:name="com.example.ngdungocsach.user.BookDetailActivity"
            android:exported="false" />
        <activity
            android:name="com.example.ngdungocsach.auth.LoginActivity"
            android:exported="false" />
        <activity
            android:name="com.example.ngdungocsach.auth.RegisterActivity"
            android:exported="false" />

        <activity
            android:name="com.example.ngdungocsach.user.FavoriteActivity"
            android:exported="false"
            android:label="@string/title_activity_favorite"
            android:theme="@style/Theme.AppReadingBook" />
        <activity
            android:name="com.example.ngdungocsach.user.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>